        body=[
            Paragraph(body=RichText('This paragraph demonstrates that #+CAPTION: followed by a blank line\nbecomes a regular keyword, not an affiliated keyword.\n')),
            BlankLine(),
            CaptionKeyword(value='This is NOT affiliated — a blank line follows.'),
            BlankLine(),
            Paragraph(body=RichText('The paragraph above is the element following the blank line, so the\n')),
