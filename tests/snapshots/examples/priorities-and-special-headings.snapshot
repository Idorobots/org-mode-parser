      Heading(
        level=1,
        title=RichText('Footnotes'),
        body=[
            Paragraph(body=RichText('[fn:special-heading] This heading "Footnotes" is a special footnote section.\nThe parser flags it with a special type distinct from a regular heading.\nIts exact title must match the value of the =org-footnote-section= variable.\n')),
            BlankLine(),
            Paragraph(body=RichText('Note: if you changed =org-footnote-section= to e.g. ="Bibliography"=, then\na heading titled =Footnotes= would be an ordinary heading, not a footnote section.\n')),
