                  ),
                ],
            ),
            Heading(
              level=2,
              title=RichText('This heading is NOT commented'),
              body=[
                  Paragraph(body=RichText('The word COMMENT only triggers the commented state when it appears in the\nCOMMENT field position — after KEYWORD and PRIORITY, before TITLE.\n')),
                  BlankLine(),
                  Paragraph(body=RichText('A heading whose *title* contains the word COMMENT is a normal heading:\n')),
                ],
            ),
