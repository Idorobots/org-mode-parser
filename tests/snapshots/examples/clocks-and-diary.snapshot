        body=[
            Paragraph(body=RichText('Diary sexp elements (=%%SEXP=) are lesser elements that can appear in any\nsection. They hold calendar expressions evaluated by the Emacs diary.\n')),
            BlankLine(),
            Paragraph(body=RichText('Each line is a separate diary sexp element:\n')),
            BlankLine(),
            Paragraph(body=RichText('%%(diary-anniversary 1969 7 20) Apollo 11 moon landing — %d years ago\n%%(diary-anniversary 1991 8 25) Linux kernel first announced — %d years\n%%(diary-anniversary 1983 1 1) The ARPANET transitions to TCP/IP — %d years\n')),
            BlankLine(),
            Paragraph(body=RichText('%%(diary-float t 4 2) Second Thursday of the month — team retrospective\n%%(diary-float t 5 3) Third Friday of the month — invoice deadline\n')),
            BlankLine(),
            Paragraph(body=RichText('A diary sexp with no arguments (a fixed-date trigger):\n%%(org-calendar-holiday)\n')),
            BlankLine(),
            Paragraph(body=RichText('Diary sexps can also appear at the heading level:\n')),
