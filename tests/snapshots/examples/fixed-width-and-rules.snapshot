                        TableRuleRow(raw='|-------+-------+-----+------|'),
                        TableRow(
                          cells=[
                              TableCell(value=RichText(' A     ')),
                              TableCell(value=RichText(' B     ')),
                              TableCell(value=RichText(' C   ')),
                              TableCell(value=RichText(' D    ')),
                            ],
                        ),
                      ],
