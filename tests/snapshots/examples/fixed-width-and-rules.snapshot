                  ),
                  BlankLine(),
                  HorizontalRule(rule='-----'),
                  BlankLine(),
                ],
            ),
            Heading(
              level=2,
              title=RichText('Adjacent rules'),
              body=[
                  Paragraph(body=RichText('Two consecutive rules are two separate horizontal rule elements:\n')),
                  BlankLine(),
                  HorizontalRule(rule='-----'),
                  HorizontalRule(rule='-----'),
                  BlankLine(),
                  Paragraph(body=RichText('Three consecutive rules:\n')),
                  BlankLine(),
                  HorizontalRule(rule='-----'),
                  HorizontalRule(rule='-----'),
                  HorizontalRule(rule='-----'),
                  BlankLine(),
                ],
            ),
            Heading(
              level=2,
              title=RichText('Rules with trailing whitespace (valid)'),
              body=[
                  Paragraph(body=RichText('The trailing spaces below do not invalidate the rule:\n')),
                  BlankLine(),
                  HorizontalRule(rule='-----   '),
                  BlankLine(),
                  HorizontalRule(rule='----------     '),
                  BlankLine(),
                  HorizontalRule(rule='-----'),
                  BlankLine(),
                ],
            ),
          ],
      ),
      Heading(
        level=1,
        title=RichText('Combinations of Fixed-Width and Horizontal Rules'),
        body=[
            BlankLine(),
            Paragraph(body=RichText('A realistic technical specification pattern:\n')),
            BlankLine(),
          ],
        children=[
            Heading(
              level=2,
              title=RichText('Protocol message format'),
              body=[
                  BlankLine(),
                  Paragraph(body=RichText('The wire format for a =PARSE_REQUEST= message is as follows:\n')),
                  BlankLine(),
                  HorizontalRule(rule='-----'),
                  BlankLine(),
                  FixedWidthBlock(body='Offset  Size  Field'),
                  FixedWidthBlock(body='------  ----  -----'),
                  FixedWidthBlock(body='     0     4  Magic number: 0x4F524721  ("ORG!")'),
                  FixedWidthBlock(body='     4     2  Version: 0x0002'),
                  FixedWidthBlock(body='     6     2  Flags (bitfield)'),
                  FixedWidthBlock(body='     8     4  Payload length (uint32, big-endian)'),
                  FixedWidthBlock(body='    12     N  Payload (UTF-8 encoded Org source)'),
                  BlankLine(),
                  HorizontalRule(rule='-----'),
                  BlankLine(),
                  Paragraph(body=RichText('Flags field (2 bytes):\n')),
                  BlankLine(),
                  FixedWidthBlock(body='Bit 15: strict_mode     — fail on unrecognised syntax'),
                  FixedWidthBlock(body='Bit 14: include_src     — parse source block contents'),
                  FixedWidthBlock(body='Bit 13: resolve_links   — resolve fuzzy links at parse time'),
                  FixedWidthBlock(body='Bits 12-0: reserved, must be zero'),
                  BlankLine(),
                  HorizontalRule(rule='-----'),
                  BlankLine(),
                  Paragraph(body=RichText('Response format:\n')),
                  BlankLine(),
                  FixedWidthBlock(body='Offset  Size  Field'),
                  FixedWidthBlock(body='     0     4  Magic: 0x4F524752  ("ORGR")'),
                  FixedWidthBlock(body='     4     4  Status code (0 = success)'),
                  FixedWidthBlock(body='     8     4  Node count'),
                  FixedWidthBlock(body='    12     4  Result length'),
                  FixedWidthBlock(body='    16     N  Result payload (JSON or msgpack)'),
                  BlankLine(),
                  HorizontalRule(rule='-----'),
                  BlankLine(),
                ],
            ),
            Heading(
              level=2,
              title=RichText('Version history'),
              body=[
                  BlankLine(),
                  HorizontalRule(rule='-----'),
                  BlankLine(),
                  FixedWidthBlock(body='v2.0.0  2025-01-06  Rewrote parser core using tree-sitter grammar.'),
                  FixedWidthBlock(body='                    Reduced parse time by 75%. Broke several edge-case'),
                  FixedWidthBlock(body='                    behaviours that are now tracked in the issue list.'),
                  BlankLine(),
                  HorizontalRule(rule='-----'),
                  BlankLine(),
                  FixedWidthBlock(body='v1.5.2  2024-11-20  Fixed off-by-one in clock duration parsing.'),
                  FixedWidthBlock(body='                    Fixed radio target matching for targets containing markup.'),
                  BlankLine(),
                  HorizontalRule(rule='-----'),
                  BlankLine(),
                  FixedWidthBlock(body='v1.5.0  2024-10-01  Added citation object support (Org 9.5 syntax).'),
                  FixedWidthBlock(body='                    Added inline source block support.'),
                  FixedWidthBlock(body='                    Deprecated the orgparse compatibility shim.'),
                  BlankLine(),
                  HorizontalRule(rule='-----'),
                  BlankLine(),
                  FixedWidthBlock(body='v1.0.0  2024-06-15  Initial public release.'),
                  BlankLine(),
                  HorizontalRule(rule='-----'),
                ],
            ),
          ],
