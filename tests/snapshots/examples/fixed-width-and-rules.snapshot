Document(
  filename='examples/fixed-width-and-rules.org',
  title=RichText('Technical Specification Fragment — Fixed-Width Areas and Horizontal Rules'),
  author=RichText('Blorcus Grumwiddle'),
  category=RichText('fixed-width-and-rules'),
  body=[
      BlankLine(),
    ],
  children=[
      Heading(
        level=1,
        title=RichText('Fixed-Width Areas'),
        body=[
            BlankLine(),
            Paragraph(body=RichText('A fixed-width area consists of one or more consecutive lines beginning with\n=:= followed by a space (or end of line).\n')),
            BlankLine(),
          ],
        children=[
            Heading(
              level=2,
              title=RichText('Basic fixed-width areas'),
              body=[
                  BlankLine(),
                  FixedWidthBlock(body='This is a single fixed-width line.'),
                  BlankLine(),
                  FixedWidthBlock(body=''),
                  FixedWidthBlock(body='An empty fixed-width line (the colon alone forms a valid fixed-width line).'),
                  FixedWidthBlock(body=''),
                  BlankLine(),
                  FixedWidthBlock(body='Fixed-width area'),
                  FixedWidthBlock(body='spanning multiple consecutive lines.'),
                  FixedWidthBlock(body='Each line begins with ": ".'),
                  FixedWidthBlock(body='The content is preserved verbatim — including   extra   spaces.'),
                  BlankLine(),
                ],
            ),
            Heading(
              level=2,
              title=RichText('Fixed-width areas showing code and terminal output'),
              body=[
                  Paragraph(body=RichText('Terminal session:\n')),
                  BlankLine(),
                  FixedWidthBlock(body='$ cargo build --release'),
                  FixedWidthBlock(body='   Compiling org-parser v0.1.0'),
                  FixedWidthBlock(body='    Finished release [optimized] target(s) in 12.43s'),
                  FixedWidthBlock(body='     Running `target/release/org-parser`'),
                  BlankLine(),
                  FixedWidthBlock(body='$ ./target/release/org-parser examples/simple.org'),
                  FixedWidthBlock(body='Parsed 1 heading in 0.003ms.'),
                  BlankLine(),
                  Paragraph(body=RichText('Configuration file content:\n')),
                  BlankLine(),
                  FixedWidthBlock(body='[parser]'),
                  FixedWidthBlock(body='max_nesting_depth = 32'),
                  FixedWidthBlock(body='strict_mode = true'),
                  FixedWidthBlock(body='encoding = "utf-8"'),
                  FixedWidthBlock(body=''),
                  FixedWidthBlock(body='[output]'),
                  FixedWidthBlock(body='format = "json"'),
                  FixedWidthBlock(body='pretty_print = true'),
                  FixedWidthBlock(body='include_positions = true'),
                  BlankLine(),
                ],
            ),
            Heading(
              level=2,
              title=RichText('Fixed-width area with special characters'),
              body=[
                  FixedWidthBlock(body='Line with *asterisks* — not markup here (fixed-width is verbatim).'),
                  FixedWidthBlock(body='Line with /slashes/ — also not italic.'),
                  FixedWidthBlock(body='Line with [[link syntax]] — not a link.'),
                  FixedWidthBlock(body='Line with #+KEYWORD: — not a keyword.'),
                  FixedWidthBlock(body='Line with a trailing backslash \\'),
                  FixedWidthBlock(body='Line with a blank colon below:'),
                  BlankLine(),
                  FixedWidthBlock(body=''),
                  BlankLine(),
                ],
            ),
            Heading(
              level=2,
              title=RichText('Fixed-width area terminated by a paragraph'),
              body=[
                  FixedWidthBlock(body='First area, lines 1–3.'),
                  FixedWidthBlock(body='Line 2 of the first area.'),
                  FixedWidthBlock(body='Line 3 of the first area.'),
                  BlankLine(),
                  Paragraph(body=RichText('This paragraph terminates the fixed-width area above (non-fixed-width line).\n')),
                  BlankLine(),
                  FixedWidthBlock(body='Second area, after the paragraph.'),
                  FixedWidthBlock(body='The two areas are distinct fixed-width elements.'),
                  BlankLine(),
                ],
            ),
            Heading(
              level=2,
              title=RichText('Fixed-width vs fixed-width line termination rule'),
              body=[
                  Paragraph(body=RichText('A fixed-width area ends the moment a line does not start with =:= followed\nby a space or end of line. The following demonstrates the boundary:\n')),
                  BlankLine(),
                  FixedWidthBlock(body='Part of the area.'),
                  FixedWidthBlock(body='Also part of the area.'),
                  Paragraph(body=RichText('This line starts with no colon — it terminates the area and is a paragraph.\n')),
                  FixedWidthBlock(body='A new, separate fixed-width area begins here.'),
                  BlankLine(),
                ],
            ),
            Heading(
              level=2,
              title=RichText('Fixed-width area inside a drawer'),
              body=[
                  Drawer(
                    name='TECHNICAL_NOTES',
                    body=[
                        FixedWidthBlock(body='Heap allocation profile (1M document corpus):'),
                        FixedWidthBlock(body='  Headings:          38.2 MiB'),
                        FixedWidthBlock(body='  Paragraphs:        241.7 MiB'),
                        FixedWidthBlock(body='  Properties:        12.4 MiB'),
                        FixedWidthBlock(body='  Blocks:            19.8 MiB'),
                        FixedWidthBlock(body='  Total:             312.1 MiB'),
                        FixedWidthBlock(body=''),
                        FixedWidthBlock(body='Peak RSS: 487 MiB (during link resolution pass)'),
                      ],
                  ),
                  BlankLine(),
                ],
            ),
            Heading(
              level=2,
              title=RichText('Fixed-width area inside a list item'),
              body=[
                  Paragraph(body=RichText('Benchmark results by backend:\n')),
