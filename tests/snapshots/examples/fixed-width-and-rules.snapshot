                  BlankLine(),
                  List(
                    items=[
                        ListItem(
                          bullet='-',
                          first_line=RichText('orgparse (Python)'),
                          body=[
                              FixedWidthBlock(body='Parse time:       980 ms'),
                              FixedWidthBlock(body='Memory:           210 MiB'),
                              FixedWidthBlock(body='Accuracy:        ~95% (many edge cases unsupported)'),
                            ],
                        ),
                      ],
                  ),
                  BlankLine(),
                  HorizontalRule(rule='-----'),
                  BlankLine(),
                ],
            ),
          ],
      ),
      Heading(
        level=1,
        title=RichText('Horizontal Rules'),
        body=[
            Paragraph(body=RichText('A horizontal rule is a line of at least five consecutive hyphens and nothing else\n(trailing whitespace is acceptable).\n')),
            BlankLine(),
          ],
        children=[
            Heading(
              level=2,
              title=RichText('Minimum-length rule (five hyphens)'),
              body=[
                  BlankLine(),
                  HorizontalRule(rule='-----'),
                  BlankLine(),
                ],
            ),
            Heading(
              level=2,
              title=RichText('Longer rules'),
              body=[
                  HorizontalRule(rule='----------'),
                  BlankLine(),
                  HorizontalRule(rule='--------------------------------------------------'),
                  BlankLine(),
                ],
            ),
            Heading(
              level=2,
              title=RichText('Rules as section dividers'),
              body=[
                  Paragraph(body=RichText('This section uses horizontal rules to visually delimit content regions.\n')),
                  BlankLine(),
                  Paragraph(body=RichText('Preamble paragraph with introductory remarks.\n')),
                  BlankLine(),
                  HorizontalRule(rule='-----'),
                  BlankLine(),
                  Paragraph(body=RichText('First region: core concepts.\n')),
                  BlankLine(),
                  Paragraph(body=RichText('Content of the first region.\nMore content.\n')),
                  BlankLine(),
                  HorizontalRule(rule='-----'),
                  BlankLine(),
                  Paragraph(body=RichText('Second region: advanced topics.\n')),
                  BlankLine(),
                  Paragraph(body=RichText('Content of the second region.\n')),
                  BlankLine(),
                  HorizontalRule(rule='-----'),
                  BlankLine(),
                  Paragraph(body=RichText('Third region: appendix material.\n')),
                  BlankLine(),
                  Paragraph(body=RichText('Content of the third region.\n')),
                  BlankLine(),
                  HorizontalRule(rule='-----'),
                  BlankLine(),
                ],
            ),
            Heading(
              level=2,
              title=RichText('Rules between different element types'),
              body=[
                  Paragraph(body=RichText('A paragraph before the rule.\n')),
                  BlankLine(),
                  HorizontalRule(rule='-----'),
                  BlankLine(),
                  Table(
                    rows=[
                        TableRow(
                          cells=[
                              TableCell(value=RichText(' Table ')),
                              TableCell(value=RichText(' after ')),
                              TableCell(value=RichText(' the ')),
                              TableCell(value=RichText(' rule ')),
