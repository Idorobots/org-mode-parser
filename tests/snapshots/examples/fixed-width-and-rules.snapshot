                  BlankLine(),
                  HorizontalRule(rule='-----'),
                  BlankLine(),
                  FixedWidthBlock(body='Fixed-width area after another rule.'),
                  FixedWidthBlock(body='Second line of the fixed-width area.'),
                  BlankLine(),
                  HorizontalRule(rule='-----'),
                  BlankLine(),
                  List(
                    items=[
                        ListItem(bullet='-', first_line=RichText('A list after a rule.')),
                        ListItem(bullet='-', first_line=RichText('Second item.')),
                        ListItem(bullet='-', first_line=RichText('Third item.')),
                      ],
                  ),
                  BlankLine(),
                  HorizontalRule(rule='-----'),
                  BlankLine(),
                  QuoteBlock(
                    body=[
                        Paragraph(body=RichText('A block quote after a rule.\n')),
