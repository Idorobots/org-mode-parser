Document(
  filename='examples/footnotes.org',
  title=RichText('A Brief History of Punctuation — Footnote Showcase'),
  author=RichText('Quorra Briskett'),
  category=RichText('footnotes'),
  body=[
      BlankLine(),
    ],
  children=[
      Heading(
        level=1,
        title=RichText('Standard Footnote References and Definitions'),
        body=[
            BlankLine(),
            Paragraph(body=RichText('The comma, whose origins can be traced to the Greek scholars of Alexandria,[fn:1]\nwas not used consistently in European manuscripts until the advent of movable\ntype printing in the fifteenth century.[fn:2]\n')),
            BlankLine(),
            Paragraph(body=RichText('The semicolon is a relative latecomer among punctuation marks.[fn:semicolon]\nIt first appeared in Italian humanist printing around 1494[fn:3] and was\nsystematised by Aldus Manutius the Elder,[fn:aldus] whose press in Venice\nbecame the model for scholarly typography across Europe.\n')),
            BlankLine(),
            Paragraph(body=RichText('The em dash — beloved by writers, despised by copy editors[fn:4] — has no\nsingle origin story. It derives from a longer tradition of manuscript\nannotation marks.[fn:5]\n')),
            BlankLine(),
            Paragraph(body=RichText('[fn:1] Aristophanes of Byzantium (c. 257–180 BCE) is often credited with\ndevising the earliest systematic punctuation system for Greek texts, using\nthree levels of dot placement to indicate short, medium, and long pauses.\n')),
            BlankLine(),
            Paragraph(body=RichText("[fn:2] The earliest printed books, incunabula, often had no punctuation at all,\nleaving spaces for readers or scribes to add marks by hand. Gutenberg's\n42-line Bible (c. 1455) is a notable early example.\n")),
            BlankLine(),
            Paragraph(body=RichText('[fn:semicolon] The word "semicolon" itself is a compound of the Greek /semi/ (half)\nand /colon/ (member or clause). Its modern name did not stabilise until the\nseventeenth century in English usage.\n')),
            BlankLine(),
            Paragraph(body=RichText("[fn:3] Specifically, Pietro Bembo's /De Aetna/ (1495), printed by Aldus Manutius,\nis frequently cited as the earliest surviving printed work to use the semicolon\nconsistently. The date is sometimes given as 1494 in sources that use the old\ncalendar.\n")),
            BlankLine(),
            Paragraph(body=RichText('[fn:aldus] Aldus Manutius (1449–1515) also invented the italic typeface and the\nportable octavo book format, transforming books from lectern objects to pocket\ncompanions. See [[https://en.wikipedia.org/wiki/Aldus_Manutius][his Wikipedia article]] for an overview.\n')),
            BlankLine(),
            Paragraph(body=RichText('[fn:4] The Chicago Manual of Style (17th ed., 2017) devotes §6.85–6.89 to the em\ndash, noting that it "is perhaps the most versatile punctuation mark" while\ncautioning against overuse.\n')),
            BlankLine(),
            Paragraph(body=RichText('[fn:5] Specifically, the medieval /positura/ system included marks resembling\nmodern dashes used to indicate pauses at the end of a clause.\n')),
            BlankLine(),
            HorizontalRule(rule='-----'),
            BlankLine(),
          ],
      ),
      Heading(
        level=1,
        title=RichText('Inline Footnotes'),
        body=[
            Paragraph(body=RichText('Inline footnotes embed the definition directly at the point of reference.\n')),
            BlankLine(),
            Paragraph(body=RichText('The interrobang[fn:interrobang:The interrobang (‽) is a non-standard punctuation\nmark combining the functions of a question mark and an exclamation point. It was\nproposed by Wulbert Grumshaw in 1962 and has never achieved wide adoption in\nformal writing.] is the most whimsical of all punctuation marks.\n')),
            BlankLine(),
            Paragraph(body=RichText('The Oxford comma[fn:oxford:Also called the serial comma or Harvard comma, it is\nthe comma placed before the conjunction in a list of three or more items. Its\nuse is *mandatory* in American English by most style guides, but /discouraged/\nin British English by many publishers.] divides writers into two irreconcilable camps.\n')),
            BlankLine(),
            Paragraph(body=RichText('The pilcrow (¶)[fn:pilcrow:The pilcrow derives from the Latin /capitulum/ (chapter)\nvia Old French /paragraphe/. In medieval manuscripts, it was drawn in red or blue\nink by a rubricator — a specialist scribe — to mark paragraph breaks. See also:\n[[https://en.wikipedia.org/wiki/Pilcrow][Wikipedia on the pilcrow]].] marks\nthe paragraph in proofreading and older typography conventions.\n')),
            BlankLine(),
            Paragraph(body=RichText('An inline footnote with a very short definition: the slash is called a\nsolidus[fn:solidus:From Latin /solidus/, a gold coin whose abbreviation /s/ was\nwritten in the numerator position of the price fraction.] in formal contexts.\n')),
            BlankLine(),
            HorizontalRule(rule='-----'),
            BlankLine(),
          ],
      ),
      Heading(
        level=1,
        title=RichText('Anonymous Footnotes'),
        body=[
            Paragraph(body=RichText('Anonymous footnotes have no label and cannot be referenced by name — each\noccurrence is a fresh footnote.\n')),
            BlankLine(),
            Paragraph(body=RichText('The question mark originated in medieval scribal practice[fn::The Latin word\n/quaestio/ (question) was abbreviated as =qo=, which scribes eventually\ncombined into a single glyph — a =q= over an =o= — that gradually evolved\ninto the modern =?=.] and is now universal across writing systems.\n')),
            BlankLine(),
            Paragraph(body=RichText('The exclamation mark has a similarly murky history.[fn::One theory holds that\nit derives from the Latin word /io/ (an exclamation of joy), written vertically\nwith the =i= above the =o= — again a scribal compression that became a glyph.\nAnother theory links it to medieval manuscript =nota= (note) marks.]\n')),
            BlankLine(),
            Paragraph(body=RichText('Both anonymous footnotes above are distinct even though they appear in the same\nsection. They will receive sequential numbers in the rendered output.\n')),
            BlankLine(),
            HorizontalRule(rule='-----'),
            BlankLine(),
          ],
      ),
      Heading(
        level=1,
        title=RichText('Footnotes with Complex Content'),
        body=[
            Paragraph(body=RichText('Standard footnotes can contain multiple paragraphs, lists, tables, and markup.\n')),
            BlankLine(),
            Paragraph(body=RichText('The history of the apostrophe is entangled with the history of the elision mark\nin Greek.[fn:apostrophe]\n')),
            BlankLine(),
            Paragraph(body=RichText("[fn:apostrophe] The apostrophe entered English in the sixteenth century, initially\nto mark the omission of a letter (as in /don't/ for /do not/). Its use as a\npossessive marker came later and was inconsistently applied until the nineteenth\ncentury.\n")),
            BlankLine(),
            Paragraph(body=RichText('Key functions of the modern apostrophe:\n')),
            BlankLine(),
            List(
              items=[
                  ListItem(bullet='-', first_line=RichText("*Contraction*: marking omitted letters (=it's=, =don't=, =they're=).")),
                  ListItem(bullet='-', first_line=RichText("*Possession*: indicating ownership (=the dog's lead=, =the dogs' leads=).")),
                  ListItem(bullet='-', first_line=RichText("*Plurals* (controversial): some style guides permit =the 1990's= — others forbid it.")),
                  ListItem(bullet='-', first_line=RichText("*Omission in poetry*: =o'er=, ='twas=, =ne'er=.")),
                ],
            ),
            BlankLine(),
            Paragraph(body=RichText('Misuse statistics[fn:7]:\n')),
            BlankLine(),
            Table(
              rows=[
                  TableRow(
                    cells=[
                        TableCell(value=RichText(' Error type                  ')),
                        TableCell(value=RichText(' Frequency (%) ')),
                      ],
                  ),
                  TableRuleRow(raw='|-----------------------------+---------------|'),
                  TableRow(
                    cells=[
                        TableCell(value=RichText(" Greengrocer's apostrophe    ")),
                        TableCell(value=RichText('            42 ')),
                      ],
                  ),
                  TableRow(
                    cells=[
                        TableCell(value=RichText(' Missing possessive          ')),
                        TableCell(value=RichText('            28 ')),
                      ],
                  ),
                  TableRow(
                    cells=[
                        TableCell(value=RichText(" /It's/ vs /its/ confusion   ")),
                        TableCell(value=RichText('            19 ')),
                      ],
                  ),
                  TableRow(
                    cells=[
                        TableCell(value=RichText(' Other                       ')),
                        TableCell(value=RichText('            11 ')),
                      ],
                  ),
                ],
            ),
            BlankLine(),
            Paragraph(body=RichText('[fn:7] These figures are illustrative and not derived from a real corpus study.\nSee [cite:@crystal2003] for actual quantitative analysis of punctuation errors\nin learner writing.\n')),
            BlankLine(),
            HorizontalRule(rule='-----'),
            BlankLine(),
          ],
      ),
      Heading(
        level=1,
        title=RichText('Footnote Section'),
        body=[
            Paragraph(body=RichText('The heading whose title equals =org-footnote-section= (default: "Footnotes") is\ntreated specially by the parser — it is a "footnote section".\n')),
            BlankLine(),
          ],
      ),
      Heading(
        level=1,
        title=RichText('Footnotes'),
        body=[
            BlankLine(),
            Paragraph(body=RichText('[fn:numeric-only] A footnote using a purely numeric label. Numeric labels are\ntreated identically to word labels by the parser — the distinction is only\ncosmetic in the source.\n')),
            BlankLine(),
            Paragraph(body=RichText('[fn:10] Another numeric-label footnote, demonstrating that label numbers need\nnot be sequential or start at 1.\n')),
            BlankLine(),
            Paragraph(body=RichText('[fn:multiword-label-with-hyphens] Labels can contain hyphens and underscores\nin addition to alphanumeric characters: =fn:my_label-2= is a valid label.\n')),
          ],
      ),
    ],
)